    "@vitejs/plugin-react": "^4.3.0",
    "cross-env": "^10.1.0",
    "electron": "^34.3.0",
    "electron-builder": "^25.1.0",
    "electron-vite": "^2.3.0",
    "png-to-ico": "^2.1.8",
    "react": "^18.3.0",
    "react-dom": "^18.3.0",
    "sharp": "^0.33.5",
    "tailwindcss": "^4.0.0",
