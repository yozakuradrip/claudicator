{
  "compilerOptions": {
    "target": "ES2022",
    "module": "CommonJS",
    "moduleResolution": "bundler",
    "lib": ["ES2022"],
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "composite": true,
    "types": ["node", "electron-vite/node"],
    "paths": {
      "@shared/*": ["../shared/*"],
      "@app/*": ["./src/*"]
    }
  },
  "include": [
    "electron.vite.config.*",
    "src/main/**/*",
    "src/preload/**/*",
    "../shared/main/**/*",
    "../shared/preload/**/*"
  ]
}
